# ================================================
# FLAMINGNEWS — Root .env.example
# ================================================

# Backend Laravel
NEWSAPI_KEY=your_newsapi_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Database (MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=flamingnews
DB_USERNAME=root
DB_PASSWORD=

# Clustering microservice
CLUSTERING_SERVICE_URL=http://localhost:8765

# App
APP_URL=http://localhost:8000
APP_ENV=local
APP_DEBUG=true
